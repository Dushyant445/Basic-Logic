using System;

namespace PalindromeString { 

    class Dushyant
    {
        public static void Main()
        {
            string str = "nitin";
            string rev = "";

            for(int i=str.Length-1; i>=0; i--)
            {
                rev = rev + str[i];
            }
            if(str == rev)
            {
                Console.WriteLine("The String is palindrome");
            }
            else
            {
                Console.WriteLine("The String is not palindrome");
            }
        }
    }


}
