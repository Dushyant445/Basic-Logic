using System;

class Dushyant
{
    public static void Main(string[] args)
    {
        string str = "Dusshyyaant";

        for(int i = 0; i<str.Length; i++)
        {
            int count = 1;

            for(int j = i+1; j<str.Length; j++)
            {
                if (str[i] == str[j])
                {
                    count++;
                }
            }
            if (count > 1)
            {
                Console.WriteLine(str[i]);
            }
        }
    }
}
