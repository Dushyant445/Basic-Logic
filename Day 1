using System;

namespace StringRev {

    class Dushyant
    {
       public static void Main()
        {
            string str = "Dushyant";
            string rev = "";

            for (int i = str.Length - 1; i >= 0; i--)
            {
                rev = rev + str[i];
            }
            Console.WriteLine(" Rev String : " + rev);
        }
    }
}
